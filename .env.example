# ------------------------------------------------------------------------------
# GBM Invest-Alerts Analyzer - Environment Configuration
# ------------------------------------------------------------------------------

# Application Port
PORT=3000

# Email Mock Mode
# When MOCK_EMAIL=true, alerts will log the beautiful HTML email content to the 
# terminal console instead of trying to send them. This allows immediate testing.
# Set this to false to send actual emails.
MOCK_EMAIL=true

# SMTP Configuration (Example for Gmail)
# Note: For security, never push real credentials to Git repositories.
#
# IMPORTANT FOR GMAIL USERS:
# Google no longer allows using your regular password in third-party scripts.
# To make this work:
# 1. Go to your Google Account -> Security.
# 2. Turn on "2-Step Verification" (Two-Factor Authentication).
# 3. Search for "App Passwords" or go to Google Account app passwords page.
# 4. Generate a new password under the name "GBM Alerts" (select App: Other).
# 5. Copy the 16-character code and paste it below in SMTP_PASS (without spaces).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=abcd-efgh-ijkl-mnop

# Target recipient for investment alerts
EMAIL_TO=your_recipient@gmail.com
